{
  "name": "",
  "description": "支持淡入、缩放、缩放淡入、上滑淡入、下滑淡入、左滑淡入、右滑淡入、上滑进入、下滑进入、左滑进入、右滑进入等动画方式",
  "tutorial": "https://www.uxframe.cn/component/transition.html",
  "attributes": [
    {
      "name": "[event]beforeEnter",
      "description": "Function | 进入前触发",
      "type": "Function"
    },
    {
      "name": "[event]enter",
      "description": "Function | 进入中触发",
      "type": "Function"
    },
    {
      "name": "[event]afterEnter",
      "description": "Function | 进入后触发",
      "type": "Function"
    },
    {
      "name": "[event]beforeLeave",
      "description": "Function | 离开前触发",
      "type": "Function"
    },
    {
      "name": "[event]leave",
      "description": "Function | 离开中触发",
      "type": "Function"
    },
    {
      "name": "[event]afterLeave",
      "description": "Function | 离开后触发",
      "type": "Function"
    },
    {
      "name": "[event]transitionend",
      "description": "Function | 动画结束后触发",
      "type": "Function"
    },
    {
      "name": "show",
      "description": "Boolean | 显示状态 （默认 false ）",
      "type": "{\n\t\t    type: Boolean,\n\t\t    default: false\n\t\t}"
    },
    {
      "name": "mode",
      "description": "String | 动画模式 （默认 fade ）",
      "type": "{\n\t\t    type: String,\n\t\t    default: 'fade'\n\t\t}"
    },
    {
      "name": "duration",
      "description": "Number | 动画的执行时间，单位ms （默认 300 ）",
      "type": "{\n\t\t    type: Number,\n\t\t    default: 300\n\t\t}"
    },
    {
      "name": "timingFunction",
      "description": "String | 使用的动画过渡函数 （默认 ease-out ）",
      "type": "{\n\t\t    type: String,\n\t\t    default: 'ease-out'\n\t\t}"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "{\n\t\t\ttype: Array as PropType<Array<any>>,\n\t\t\tdefault: (): any[] => [] as any[]\n\t\t}"
    }
  ]
}