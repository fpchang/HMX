{
	"bsonType": "object",
	"required": [],
	"permission": {
		"read": true,
		"create": true,
		"update": true,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "ID，系统自动生成"
		},
		"hm_token": {
			"description": "token",
			"bsonType": "string"
		},
		"idCard": {
			"description": "身份证",
			"bsonType": "string"
		},
		"vipStartDateStamp": {
			"description": "vip开始时间戳",
			"bsonType": "timestamp"
		},
		"isVip": {
			"description": "是否vip",
			"bsonType": "bool"
		},
		"nickName": {
			"description": "昵称",
			"bsonType": "string"
		},
		"account": {
			"description": "账号",
			"bsonType": "string"
		},
		"password": {
			"description": "密码",
			"bsonType": "string"
		},
		"email": {
			"description": "邮箱",
			"bsonType": "string"
		},
		"smscode": {
			"description": "短信验证码",
			"bsonType": "string"
		},

		"phone": {
			"description": "手机号",
			"title": "手机号",
			"bsonType": "string",
			"minLength": 11,
			"pattern": "^[1][3,4,5,6,7,8,9][0-9]{9}$",
			"errorMessage": {
				//"required": "手机号不能为空",
				"minLength": "手机号不能小于 11 个字符",
				"pattern": "手机号格式不正确"
			}
		},
		"userId":{
			"description": "用户id--弃用",
			"bsonType": "string"
		},
		"userName": {
			"description": "用户名",
			"bsonType": "string"
		},
		"vipEndDate": {
			"description": "vip结束时间",
			"bsonType": "string"
		},
		"vipEndDateStamp": {
			"description": "vip结束日期时间戳",
			"bsonType": "timestamp"
		},
		"vipStartDate": {
			"description": "vip开始时间",
			"bsonType": "string"
		},
		"wxNickName": {
			"description": "微信昵称",
			"bsonType": "string"
		},
		"wxOpenId": {
			"description": "微信openid",
			"bsonType": "string"
		},
		"accountStatus": {
			"description": "账户状态 1 正常，9注销中，10 无效",
			"bsonType": "int",
			"defaultValue": 1
		},
		"closeAccountDateTime": {
			"description": "注销日期，注销后7天开始注销",
			"bsonType": "timestamp"
		},
		"blongEmployment": {
			"description": "所属于店铺",
			"bsonType": "array"
		},
		"avatar": {
			"description": "头像",
			"bsonType": "string"
		}
	}
}