		height: 150px;
		padding: 15px;
		background: #fafafa;
		display: flex;
		flex-direction: column;
		/* gap: 10px;*/
		font-size: 16px;
		border-top-left-radius: 12px;
		border-top-right-radius: 12px;

		.tit {
			font-weight: 400;
			font-size: 18px;
			color: #666;
		}

		.txt-content {
			font-size: 16px;
			/*text-indent: 16px;*/
			color: #999;
		}

		.control {
			display: flex;
			align-items: center;
			justify-content: center;

			/* gap: 15px;*/
			.btn-style {
				background: #fff;
				width: 100px;
				height: 35px;
				border: 1px solid #eee;
				text-align: center;
				line-height: 35px;
				border-radius: 5px;
				color: #007aff;
			}

