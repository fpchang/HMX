{
  "name": "",
  "description": "支持滑动距离自动切换到锚点",
  "tutorial": "https://www.uxframe.cn/component/sidebar.html",
  "attributes": [
    {
      "name": "[event]change",
      "description": "Function | 当前选择下标改变时触发",
      "type": "Function"
    },
    {
      "name": "[event]anchor",
      "description": "Function | 当要滚动目标时触发",
      "type": "Function"
    },
    {
      "name": "[event]update:modelValue",
      "description": "",
      "type": "Event"
    },
    {
      "name": "default",
      "description": "Slot | 默认插槽",
      "type": "Slot"
    },
    {
      "name": "theme",
      "description": "String | 按钮类型 (默认 info)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'primary'\n\t\t}"
    },
    {
      "name": "modelValue",
      "description": "Number | 双向绑定值 (默认 0)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "datas",
      "description": "UxTab[] | sidebar列表",
      "type": "{\n\t\t\ttype: Array as PropType<UxTab[]>,\n\t\t\tdefault: () : UxTab[] => [] as UxTab[]\n\t\t}"
    },
    {
      "name": "type",
      "description": "String | 类型 (默认 line)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'line'\n\t\t}"
    },
    {
      "name": "anim",
      "description": "String | 动效类型 (默认 scroll)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'scroll'\n\t\t}"
    },
    {
      "name": "anchorId",
      "description": "String | 锚点ScrollId",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "width",
      "description": "Any | 宽度 (默认 auto)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "height",
      "description": "Any | 高度 (默认 auto)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "tabWidth",
      "description": "Any | Tab宽度 (默认 100)",
      "type": "{\n\t\t\tdefault: 100\n\t\t}"
    },
    {
      "name": "tabHeight",
      "description": "Any | Tab高度 (默认 44)",
      "type": "{\n\t\t\tdefault: 44\n\t\t}"
    },
    {
      "name": "corner",
      "description": "Any | 圆角 (默认 0)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "selectedColor",
      "description": "String | 选中颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "unselectedColor",
      "description": "String | 未选中颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "background",
      "description": "String | 背景色 (默认 $ux.Conf.backgroundColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "backgroundDark",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "lineColor",
      "description": "String | 线颜色 selectedColor 优先级更高",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "lineWidth",
      "description": "Any | 线宽度 0则自动适配 (默认 2)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "lineHeight",
      "description": "Any | 线高度、点直径 (默认 30)",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "fontSize",
      "description": "Any | 字体大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "selectSize",
      "description": "Any | 选中字体大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "bold",
      "description": "Boolean | 字体加粗 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "selectBold",
      "description": "Boolean | 选中字体加粗 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "duration",
      "description": "Number | 过渡时间 (默认 300)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 300\n\t\t}"
    },
    {
      "name": "padding",
      "description": "Any | 内部padding (默认 12)",
      "type": "{\n\t\t\tdefault: 12\n\t\t}"
    },
    {
      "name": "offset",
      "description": "Any | 锚点偏移距离 (默认 0)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    }
  ]
}