      "description": "Boolean | 内容是否垂直居中 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "required",
      "description": "Boolean | 是否显示必填星号（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "path",
      "description": "String | 页面跳转路径",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "show",
      "description": "Boolean | 是否显示cell（默认 true ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "disabled",
      "description": "Boolean | 是否禁用cell（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "hover",
      "description": "Boolean | 显示点击态 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "margin",
      "description": "Array | 边距 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "{\n\t\t\ttype: Array as PropType<Array<any>>,\n\t\t\tdefault: (): any[] => [] as any[]\n\t\t}"
    },
    {
      "name": "mt",
      "description": "Any | 距上 单位px",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "mr",
      "description": "Any | 距右 单位px",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "mb",
      "description": "Any | 距下 单位px",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "ml",
      "description": "Any | 距左 单位px",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "{\n\t\t\ttype: Array as PropType<Array<any>>,\n\t\t\tdefault: (): any[] => [] as any[]\n\t\t}"
    }
