{
  "name": "",
  "description": "支持单色、渐变色、透明度",
  "tutorial": "https://www.uxframe.cn/component/colorpicker.html",
  "attributes": [
    {
      "name": "[event]change",
      "description": "Function | 确定选择时触发",
      "type": "Function"
    },
    {
      "name": "[event]changing",
      "description": "Function | 选择时触发",
      "type": "Function"
    },
    {
      "name": "[event]close",
      "description": "Function | 关闭时触发",
      "type": "Function"
    },
    {
      "name": "[event]update:modelValue",
      "description": "",
      "type": "Event"
    },
    {
      "name": "value",
      "description": "String | 值 (rgba(255,0,0,1))",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "colors",
      "description": "RGBA[] | 预设颜色值",
      "type": "{\n\t\t\ttype: Array as PropType<RGBA[]>,\n\t\t\tdefault: (): RGBA[] => {\n\t\t\t\treturn [\n\t\t\t\t\t{ r: 60, g: 156, b: 255, a: 1 },\n\t\t\t\t\t{ r: 249, g: 174, b: 61, a: 1 },\n\t\t\t\t\t{ r: 90, g: 199, b: 37, a: 1 },\n\t\t\t\t\t{ r: 233, g: 30, b: 99, a: 1 },\n\t\t\t\t\t{ r: 156, g: 39, b: 176, a: 1 },\n\t\t\t\t\t{ r: 103, g: 58, b: 183, a: 1 },\n\t\t\t\t\t{ r: 63, g: 81, b: 181, a: 1 },\n\t\t\t\t\t{ r: 0, g: 188, b: 212, a: 1 },\n\t\t\t\t\t{ r: 0, g: 150, b: 136, a: 1 },\n\t\t\t\t\t{ r: 139, g: 195, b: 74, a: 1 },\n\t\t\t\t\t{ r: 205, g: 220, b: 57, a: 1 },\n\t\t\t\t\t{ r: 255, g: 235, b: 59, a: 1 },\n\t\t\t\t\t{ r: 255, g: 193, b: 7, a: 1 },\n\t\t\t\t\t{ r: 255, g: 152, b: 0, a: 1 },\n\t\t\t\t\t{ r: 255, g: 87, b: 34, a: 1 },\n\t\t\t\t\t{ r: 121, g: 85, b: 72, a: 1 },\n\t\t\t\t\t{ r: 48, g: 49, b: 51, a: 1 },\n\t\t\t\t\t{ r: 158, g: 158, b: 158, a: 1 },\n\t\t\t\t\t{ r: 0, g: 0, b: 0, a: 0.5 },\n\t\t\t\t\t{ r: 0, g: 0, b: 0, a: 0 },\n\t\t\t\t] as RGBA[]\n\t\t\t}\n\t\t}"
    },
    {
      "name": "title",
      "description": "String | 标题",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "titleColor",
      "description": "String | 标题颜色 (默认 $ux.Conf.titleColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "size",
      "description": "Any | 内容大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 内容颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "confirm",
      "description": "String | 确定文字 (默认 确定)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '确定'\n\t\t}"
    },
    {
      "name": "confirmColor",
      "description": "Strng | 确定文字颜色 (默认 $ux.Conf.primaryColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "btnSize",
      "description": "Any | 按钮大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "btnType",
      "description": "String | 按钮类型 (默认 normal)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'normal'\n\t\t}"
    },
    {
      "name": "btnPositon",
      "description": "String | 按钮位置 (默认 bottom)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'bottom'\n\t\t}"
    },
    {
      "name": "radius",
      "description": "Any | 圆角 (默认 $ux.Conf.radius)",
      "type": "{\n\t\t\tdefault: -1\n\t\t}"
    },
    {
      "name": "opacity",
      "description": "Number | 遮罩透明度 0-1 (默认 $ux.Conf.maskAlpha)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 0.1\n\t\t}"
    },
    {
      "name": "touchable",
      "description": "Boolean | 允许滑动关闭 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "maskClose",
      "description": "Boolean | 遮罩层关闭 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "disabled",
      "description": "Boolean | 是否禁用 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "modelValue",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    }
  ]
}