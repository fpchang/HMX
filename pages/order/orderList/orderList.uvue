.order-no {
  font-size: 22rpx;
  color: #8e8e93; /* iOS 次要文本色 */
  padding-bottom: 8rpx;
  border-bottom: 0.5rpx solid #f0f0f0;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #1c1c1e; /* iOS 主要文本色（深灰） */
  font-weight: 400;
}

.info-value {
  font-size: 28rpx;
  color: #636366; /* iOS 次要文本色（中灰） */
  font-weight: 500;
}

/* 日期卡片（内嵌式设计） */
.date-card {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 4rpx;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex: 1;
}

