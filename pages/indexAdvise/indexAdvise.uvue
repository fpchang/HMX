<script setup lang="uts">
	import { loginEvent, loginOut } from "@/store/store.uts";

	//import { ref, onMounted, computed } from "vue";
	//import { AccountService } from "@/services/AccountService";
	// const props = defineProps({
	//   message: {
	//     type: String,
	//     required: true
	//   }
	// });

	let isReading = ref(false);
	let refresher_triggered = ref(false);
	let submitLoading = ref(false);
	let agreeGetPhone = ref(false);
	let showPopu = ref(false);
	const accessin = () => {
		uni.reLaunch({
			url: "/pages/index/index",
		});
	};
	const popup_confirm = ref(null);
	const toLogin = () => {
		uni.navigateTo({
			url: "/pages/login/login",
		});
	};
	const toLoginEvent = () => {
		toLogin();
		//#ifdef MP
		//popup_confirm.value.open();
		return;
		//#endif

	};

	const agreeGetPhoneEvent = (f : boolean) : void => {
		if (f) {
			showPopu.value = false;
			toLogin();

			return;
		}
		showPopu.value = false;
	};
	const list = [
		{
			title: "订单管理",
			img: "/static/icons/homemenu/order1.png",
			info: "订单管理，快速查看入住与退房",
		},
		{
			title: "房态管理",
			img: "/static/icons/order-blue.png",
			info: "一图看清入住数据",
		}, {
			title: "房型管理",
			img: "/static/icons/homemenu/room-type1.png",
			info: "酒店房型设施数据管理",
		}, {
			title: "财务管理",
			img: "/static/icons/homemenu/income.png",
			info: "酒店收支管理与统计，一图看清营业状况",
		}, {
			title: "员工账号",
			img: "/static/icons/homemenu/employee1.png",
			info: "提供员工子账号与员工数据管理",
		}, {
			title: "酒店展示",
			img: "/static/icons/homemenu/hotel2.png",
			info: "个性化展示与分享",
		}
	];
	const navTopHeight = computed(() => {
		// #ifdef MP-WEIXIN
		return "100px";
		// #endif

		//return this.isPcShow? "0px" : "70px";
		return "70px";
	});
	const refrush = () => {
		console.log();
		refresher_triggered.value = true;
		setTimeout(() => {
			refresher_triggered.value = false;
		}, 1000);
	};
	const initData = (async () => {
		try {
			console.log("验证token");
			const res = await loginEvent();;
			console.log("验证token结果", res);
			accessin();
		} catch (error) {
			console.log("err", error);

			isReading.value = true;
		}
	});
	onLoad(() => {
		initData();
	})
	onMounted(() => {
		// uni.setNavigationBarColor({
		// 	backgroundColor: "#rgba(0,0,0,0.2)",
		// 	frontColor: "rgba(255,255,255,0.3)"
		// })
	});
</script>

