						</view>
						<view class="control-item-group">
							<!-- <view><l-icon name="solar:calendar-date-linear" size="40px"  color="#004af6" /></view>
							 --><view><text class="txt">房态管理</text></view>
						</view>
						<view class="control-item-group">
							<!-- <view><l-icon name="hugeicons:home-10" size="40px"  color="#004af6" /></view>
							 --><view><text class="txt">房型管理</text></view>
						</view>
						<view class="control-item-group">
							<!-- <view><l-icon name="lucide:chart-no-axes-combined" size="40px"  color="#004af6" /></view>
							 --><view><text class="txt">财务管理</text></view>
						</view>
						<view class="control-item-group">
							<!-- <view><l-icon name="clarity:employee-line" size="40px"  color="#004af6" /></view>
							 --><view><text class="txt">员工账号</text></view>
						</view>
						<view class="control-item-group">
							<!-- <view><l-icon name="solar:display-outline" size="40px"  color="#004af6" /></view>
							 --><view><text class="txt">酒店展示</text></view>
						</view>
						<!-- <view class="cs"></view>
						<view class="cs"></view>
						<view class="cs"></view>
						<view class="cs"></view> -->
					</view>
				</view>
			</view>
			<view style="height: 320px;"></view>
			<view class="control">
				
				<rice-button type="primary" text="登录体验" class="btn"  shape="round" color="#004af6" @click="toLoginEvent"/>
			</view>
			</view>
			
			
	<!-- #ifdef APP -->			
	</scroll-view>
	<!-- #endif -->
	<l-popup v-model="showPopu">
		<view class="popup-con">
			<view class="tit">议宿申请</view>
			<view class="txt-content">此系统需要使用手机号登录后才能使用全部功能，确认是否手机号登录</view>
			<view class="control">
				<view class="btn-style" @click="agreeGetPhoneEvent(false)">拒绝</view>
				<view class="btn-style btn-confirm" @click="agreeGetPhoneEvent(true)">允许</view>
			</view>
		</view>
	</l-popup>

</template>

<script setup>
	import {loginEvent,loginOut} from "@/store/store.uts";
	 
	//import { ref, onMounted, computed } from "vue";
	//import { AccountService } from "@/services/AccountService";
	// const props = defineProps({
	//   message: {
	//     type: String,
	//     required: true
	//   }
	// });

	let isReading = ref(false);
	let refresher_triggered = ref(false);
	let submitLoading = ref(false);
	let agreeGetPhone = ref(false);
	let showPopu = ref(false);
	const accessin = () => {
		  uni.reLaunch({
		        url: "/pages/index/index",
		      });
	};
	const popup_confirm = ref(null);
	const toLogin = () => {
		uni.navigateTo({
			url: "/pages/login/login",
		});
	};
	const toLoginEvent = () => {
		//#ifdef MP
		popup_confirm.value.open();
		return;
		//#endif
		toLogin();
	};

	const agreeGetPhoneEvent = (f:boolean):void => {
		if (f) {
			showPopu.value = false;
			toLogin();

			return;
		}
		showPopu.value = false;
	};

	const list = [
		{
			title: "首页",
			img: "https://cdn.hotelsys.fun/HM/images/advise/1.png",
			info: "酒店管理",
		},
		{
			title: "房态",
