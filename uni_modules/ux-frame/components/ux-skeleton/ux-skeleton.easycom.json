{
  "name": "",
  "description": "此组件仅是占位显示，需要辉光效果请用ux-shimmer插件包裹",
  "tutorial": "https://www.uxframe.cn/component/skeleton.html",
  "attributes": [
    {
      "name": "rows",
      "description": "String[] | 段落占位图行数, 值是宽度 (默认 '100%' )",
      "type": "{\n\t\t\ttype: Array as PropType<Array<string>>,\n\t\t\tdefault: () : Array<string> => [] as Array<string>\n\t\t}"
    },
    {
      "name": "height",
      "description": "Any[] | 段落高度 (默认 [18] )",
      "type": "{\n\t\t\tdefault: () : number[] => [18] as number[]\n\t\t}"
    },
    {
      "name": "spacing",
      "description": "Any | 段落间隔 (默认 5 )",
      "type": "{\n\t\t\tdefault: 5\n\t\t}"
    },
    {
      "name": "avatar",
      "description": "Boolean | 显示头像 (默认 32 )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "avatarWidth",
      "description": "Any | 头像宽度 (默认 32 )",
      "type": "{\n\t\t\tdefault: 32\n\t\t}"
    },
    {
      "name": "avatarHeight",
      "description": "Any | 头像高度 (默认 32 )",
      "type": "{\n\t\t\tdefault: 32\n\t\t}"
    },
    {
      "name": "shape",
      "description": "String | 头像占位图的形状 (默认 square )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'square'\n\t\t}"
    },
    {
      "name": "background",
      "description": "String | 段落背景色 (默认 #e9e9e9 )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#e9e9e9'\n\t\t}"
    },
    {
      "name": "margin",
      "description": "Array | 边距 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "mt",
      "description": "Any | 距上 单位px",
      "type": "Any"
    },
    {
      "name": "mr",
      "description": "Any | 距右 单位px",
      "type": "Any"
    },
    {
      "name": "mb",
      "description": "Any | 距下 单位px",
      "type": "Any"
    },
    {
      "name": "ml",
      "description": "Any | 距左 单位px",
      "type": "Any"
    },
    {
      "name": "padding",
      "description": "Array | 填充 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "pt",
      "description": "Any | 上内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pr",
      "description": "Any | 右内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pb",
      "description": "Any | 下内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pl",
      "description": "Any | 左内边距 单位px",
      "type": "Any"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "Array"
    }
  ]
}