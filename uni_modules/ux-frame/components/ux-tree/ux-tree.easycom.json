{
  "name": "",
  "description": "支持无限嵌套，支持异步加载",
  "tutorial": "https://www.uxframe.cn/component/tree.html",
  "attributes": [
    {
      "name": "[event]openedChange",
      "description": "Function | 打开时触发",
      "type": "Function"
    },
    {
      "name": "[event]change",
      "description": "Function | 选择时触发",
      "type": "Function"
    },
    {
      "name": "[event]click",
      "description": "Function | 点击时触发",
      "type": "Function"
    },
    {
      "name": "[event]opened-change",
      "description": "",
      "type": "Event"
    },
    {
      "name": "[event]update:modelValue",
      "description": "",
      "type": "Event"
    },
    {
      "name": "value",
      "description": "string[] | 默认值",
      "type": "Array"
    },
    {
      "name": "modelValue",
      "description": "string[] | 双向绑定",
      "type": "{\n\t\t\ttype: Array as PropType<string[]>,\n\t\t\tdefault: () : string[] => [] as string[]\n\t\t}"
    },
    {
      "name": "idKey",
      "description": "String | id key（默认 id ）",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'id'\n\t\t}"
    },
    {
      "name": "labelKey",
      "description": "String | label key（默认 label ）",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'label'\n\t\t}"
    },
    {
      "name": "nodes",
      "description": "UTSJSONObject[] | 节点数据",
      "type": "{\n\t\t\ttype: Array as PropType<Array<UTSJSONObject>>,\n\t\t\tdefault: (): UTSJSONObject[] => [] as UTSJSONObject[]\n\t\t}"
    },
    {
      "name": "includeChild",
      "description": "Boolean | 允许选择父级同时选择其所有子级（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "onlyChild",
      "description": "Boolean | 只允许选择子级（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "offset",
      "description": "Number | 子级距父级水平偏移量（默认 15 ）",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 15\n\t\t}"
    },
    {
      "name": "theme",
      "description": "String | 主题颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 文本颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '',\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '',\n\t\t}"
    },
    {
      "name": "activeColor",
      "description": "String | 选中时颜色 优先级高于主题",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '',\n\t\t}"
    },
    {
      "name": "activeDarkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '',\n\t\t}"
    },
    {
      "name": "size",
      "description": "Any | 字体大小（默认 $ux.Conf.fontSize ）",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "sizeType",
      "description": "String | 字体大小类型（默认 small ）",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'small'\n\t\t}"
    },
    {
      "name": "bold",
      "description": "Boolean | 字体加粗（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "openIcon",
      "description": "String | 打开图标",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'folderopen-filled'\n\t\t}"
    },
    {
      "name": "closeIcon",
      "description": "String | 关闭图标",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'folderclose-outline'\n\t\t}"
    },
    {
      "name": "iconSize",
      "description": "Any | 图标字体大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "customFamily",
      "description": "String | 字体family",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "disabled",
      "description": "Boolean | 是否禁用（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "openedValue",
      "type": "{\n\t\t\ttype: Array as PropType<string[]>,\n\t\t\tdefault: () : string[] => [] as string[]\n\t\t}"
    }
  ]
}