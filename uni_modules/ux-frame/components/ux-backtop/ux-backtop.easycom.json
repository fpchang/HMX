{
  "name": "",
  "description": "支持形状、图标、大小、颜色、背景色、插槽等自定义样式",
  "tutorial": "https://www.uxframe.cn/component/backtop.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "Function | 点击按钮时触发",
      "type": "Function"
    },
    {
      "name": "default",
      "description": "Slot | 默认插槽",
      "type": "Slot"
    },
    {
      "name": "parent",
      "description": "String | 父级[scroll-view list-view] id，如果未指定系统会自动查找父级或平级下的[scroll-view list-view]",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "shape",
      "description": "String | 形状（默认 circle ）",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'circle'\n\t\t}"
    },
    {
      "name": "icon",
      "description": "String | 图标 （默认 arrowup ）",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'arrowup',\n\t\t}"
    },
    {
      "name": "text",
      "description": "String | 文字 （默认 TOP ）",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'TOP',\n\t\t}"
    },
    {
      "name": "duration",
      "description": "Number | 返回顶部滚动时间 （默认 100）",
      "type": "Number"
    },
    {
      "name": "right",
      "description": "Any | 距右距离 （默认 30 ）",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "bottom",
      "description": "Any | 距底距离 （默认 100 ）",
      "type": "{\n\t\t\tdefault: 100\n\t\t}"
    },
    {
      "name": "iconSize",
      "description": "Any | 图标大小  (默认 18)",
      "type": "{\n\t\t\tdefault: 18\n\t\t}"
    },
    {
      "name": "fontSize",
      "description": "Any | 字体大小  (默认 14)",
      "type": "{\n\t\t\tdefault: 12\n\t\t}"
    },
    {
      "name": "fontBold",
      "description": "Boolean | 字体加粗 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "customFamily",
      "description": "String | 字体family",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "background",
      "description": "String | 背景色 (默认 #FFFFFF)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'rgba(196, 196, 196, 0.7)'\n\t\t}"
    },
    {
      "name": "zIndex",
      "description": "Number | 层级z-index (默认 10000)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 100\n\t\t}"
    },
    {
      "name": "fixed",
      "description": "Boolean | 固定定位 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "color",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#000000'\n\t\t}"
    }
  ]
}