{
  "name": "",
  "description": "常用字体图标集，包含了大多数常见场景的图标",
  "tutorial": "https://www.uxframe.cn/component/icon.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "Function | 文字被点击时触发",
      "type": "Function"
    },
    {
      "name": "type",
      "description": "String | 字体类型",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 字体颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "size",
      "description": "Any | 字体大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "fontFamily",
      "description": "String | 字体family (默认 ux-iconfont)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'ux-iconfont'\n\t\t}"
    },
    {
      "name": "margin",
      "description": "Array | 边距 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "mt",
      "description": "Any | 距上 单位px",
      "type": "Any"
    },
    {
      "name": "mr",
      "description": "Any | 距右 单位px",
      "type": "Any"
    },
    {
      "name": "mb",
      "description": "Any | 距下 单位px",
      "type": "Any"
    },
    {
      "name": "ml",
      "description": "Any | 距左 单位px",
      "type": "Any"
    },
    {
      "name": "padding",
      "description": "Array | 填充 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "pt",
      "description": "Any | 上内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pr",
      "description": "Any | 右内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pb",
      "description": "Any | 下内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pl",
      "description": "Any | 左内边距 单位px",
      "type": "Any"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "Array"
    },
    {
      "name": "customFamily",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    }
  ]
}