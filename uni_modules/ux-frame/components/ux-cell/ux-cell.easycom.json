{
  "name": "",
  "description": "支持配置标题、描述文本、内容及样式，左右图标、插槽，最小高度、固定高度，对齐方式",
  "tutorial": "https://www.uxframe.cn/component/cell.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "Function | 单元格点击时触发",
      "type": "Function"
    },
    {
      "name": "left",
      "description": "Slot | 左边插槽",
      "type": "Slot"
    },
    {
      "name": "right",
      "description": "Slot | 右边插槽",
      "type": "Slot"
    },
    {
      "name": "title",
      "description": "String | 标题",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "size",
      "description": "Any | 标题大小 (默认 14)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 标题颜色 (默认 $ux.Conf.fontColor)",
