{
  "name": "",
  "description": "ToastItem 消息提示项",
  "tutorial": "https://www.uxframe.cn/component/toast.html",
  "attributes": [
    {
      "name": "itemId",
      "description": "String | 唯一id",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "index",
      "description": "Number | 下标",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "logo",
      "description": "String | Logo",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "logoWidth",
      "description": "Any | Logo宽 (默认 30)",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "logoHeight",
      "description": "Any | Logo高 (默认 30)",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "logoRadius",
      "description": "Any | Logo圆角 (默认 10)",
      "type": "{\n\t\t\tdefault: 5\n\t\t}"
    },
    {
      "name": "content",
      "description": "String | 内容",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 文本颜色 优先级高于主题",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#fff'\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#fff'\n\t\t}"
    },
    {
      "name": "size",
      "description": "Any | 字体大小（默认 14 ）",
      "type": "{\n\t\t\tdefault: 14\n\t\t}"
    },
    {
      "name": "bold",
      "description": "Boolean | 字体加粗（默认 false ）",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "background",
      "description": "String | 背景色 (默认 $ux.Conf.backgroundColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#333'\n\t\t}"
    },
    {
      "name": "backgroundDark",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色 (默认 auto)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#222'\n\t\t}"
    },
    {
      "name": "borderColor",
      "description": "String | 边框颜色  (默认 $ux.Conf.borderColor )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "borderDarkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色 (默认 auto)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'auto'\n\t\t}"
    },
    {
      "name": "radius",
      "description": "Any | 圆角 (默认 30)",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "shadow",
      "description": "Boolean | 显示阴影 (默认 true )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "border",
      "description": "Boolean | 显示边框 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "scale",
      "description": "Boolean | 缩放动画 (默认 true )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "padding",
      "type": "{\n\t\t\tdefault: 10\n\t\t}"
    }
  ]
}