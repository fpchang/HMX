  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  z-index: 1;
}

/* 菜单按钮样式（iOS 原生配色） */
.menu-btn {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border: none;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  width: 80rpx; /* 每个按钮宽度80rpx，总宽度240rpx */
}

/* 查看按钮（iOS 蓝色） */
.btn-view {
  background-color: #007aff;
}

/* 修改按钮（iOS 绿色） */
.btn-edit {
  background-color: #34c759;
}

/* 删除按钮（iOS 红色） */
.btn-delete {
  background-color: #ff3b30;
}

/* iOS 轻奢风格卡片核心 */
.order-card {
  background: #ffffff;
  width: 100%;
  padding: 24rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  /* iOS 细腻阴影 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03), 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
  /* 点击反馈 */
  transition: all 0.2s ease;
  z-index: 2;
}

.order-card:active {
  background-color: #f8f8f8;
  transform: translateX(-240rpx) translateY(1rpx) !important;
}

/* 卡片头部：状态+价格 */
.card-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

/* 状态标签（iOS 圆角胶囊） */
.status-tag {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.status-success {
  background-color: rgba(52, 199, 89, 0.1);
  border: 0.5rpx solid rgba(52, 199, 89, 0.2);
}

.status-pending {
  background-color: rgba(255, 204, 0, 0.1);
  border: 0.5rpx solid rgba(255, 204, 0, 0.2);
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.status-success .status-text {
  color: #34c759; /* iOS 原生绿 */
}

.status-pending .status-text {
  color: #ffcc00; /* iOS 原生黄 */
}

/* 价格区域 */
.price-wrap {
  display: flex;
  flex-direction: row;
