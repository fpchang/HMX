{
  "name": "",
  "description": "支持上下左右位置显示，支持拖拽关闭、自动关闭，内置多种关闭动画",
  "tutorial": "https://www.uxframe.cn/component/toast.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "",
      "type": "Event"
    },
    {
      "name": "position",
      "description": "String | 显示位置 (默认 top)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'top'\n\t\t}"
    },
    {
      "name": "anim",
      "description": "String | 动画效果 (默认 fade)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'fade'\n\t\t}"
    },
    {
      "name": "max",
      "description": "Number | 最大存在个数 (默认 0 不限制)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "offset",
      "description": "Any | 偏移 (默认 15)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 15\n\t\t}"
    },
    {
      "name": "threshold",
      "description": "Any | 移动阈值 (默认 100)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 100\n\t\t}"
    },
    {
      "name": "logoWidth",
      "description": "Any | Logo宽 (默认 30)",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "logoHeight",
      "description": "Any | Logo高 (默认 30)",
      "type": "{\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "logoRadius",
      "description": "Any | Logo圆角 (默认 10)",
      "type": "{\n\t\t\tdefault: 5\n\t\t}"
    },
    {
      "name": "duration",
      "description": "Number | 关闭过渡时间 (默认 700)",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 1200\n\t\t}"
    },
    {
      "name": "autoclose",
      "description": "Boolean | 自动关闭 (默认 true )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "clickclose",
      "description": "Boolean | 点击关闭 (默认 true )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "touchclose",
      "description": "Boolean | 长按拖拽关闭 暂只支持Web (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    }
  ]
}