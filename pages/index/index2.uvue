			                        item.hotelAddress
			                      }}</text></view>
									</view>
								</view>
								<view class="select">
									<image :src="item._id==hotel_id?'/static/icons/checked.png':'/static/icons/uncheck.png'"
										class="form-icon" style="width:35px;height:35px"></image>
								
								</view>
							</view>
						</view>
						<view v-for="item in 5" style="height: 0;min-width:360px;padding:0 10px;flex:1"></view>
				
