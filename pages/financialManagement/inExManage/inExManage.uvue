		</view>
		<view  v-if="!submitLoading&&fmResult.fmList.length<1">
			<l-empty description="没有数据" />
		</view>
	</scroll-view>

	
	<view style="padding:15px 5px;background-color: #fff;display: flex;flex-direction: row;justify-content: center;" v-if="!submitLoading&&fmResult.fmList.length>0">
		<l-pagination v-model="fmResult.pageNo" :disabled="submitLoading" :total="fmResult?.count"
			:page-size="fmResult?.pageSize" :pager-count="5" :hideOnSinglePage="true" @change="pageChange"  />
	</view>
</template>

<script setup>
	import { showDialog, hideDialog } from "@/uni_modules/rice-ui";
	import { dayuts } from '@/uni_modules/lime-dayuts';
	import { TIME, getMonthDateArray } from "@/static/utils/TIME";
	import { ActionSheetAction } from "@/uni_modules/rice-ui";
	import { PickerOption, PickerEvent } from "@/uni_modules/rice-ui/index";
	import { roomTypeBean } from '@/bean/roomTypeBean';
	import { FMService } from "@/services/FMService";
	import { roomBean } from '@/bean/roomBean';
	import { FMBean, FMDataListResult } from '@/bean/FMBean';
	import { state } from "@/store/store";
	import { fmState } from "@/store/modules/fmStore.uts";
	import {userBean} from "@/bean/userBean";
	
	import { comFunction } from "@/pages/index/ComFuc";
	import fmSearchComponent from "./components/fmSearchComponent/fmSearchComponent";
	import expensesInfoCardComponent from "./components/expensesInfoCardComponent/expensesInfoCardComponent";
	import incomeInfoCardComponent from "./components/incomeInfoCardComponent/incomeInfoCardComponent";
	let submitLoading = ref(false);
	const hotel_id = computed(() => {
		return state.hotel_id;
	});
	const user = computed<userBean>(() => {
		return state.user;
	});
	const permissionList = computed(() => {
		return state.permissionList;
	})
	const currentPage = ref(1);
	const roomTypeList = computed<Array<roomTypeBean> | null>(() => {
		return state.roomTypeList;
	});
	//选择列表
	let _select_id = ref("income");
	let _search_key = ref("");
	const billType = ref("income");
	const keyword = ref("");//过滤字段
	const dateRange = ref<string[]>(getMonthDateArray());
	const columns = computed<Array<Array<PickerOption>>>(() => {
		let result : Array<Array<PickerOption>> = [[
			{ text: '收入', value: 'income' },
			{ text: '支出', value: 'expense' }
		]];
		return result;
	});


	const fmResult = ref<FMDataListResult>({
		count: 0,//总数量
		pageNo: 1,//当前页码
		pageSize: 20,//每页数量
		fmList: []//列表
	})
	const getFmList = async () => {
		submitLoading.value = true;
		uni.showLoading({
			title: ""
		})
		const fmr = await FMService.getIncomeAndExpensesDateBySearch(hotel_id.value, billType.value, keyword.value, dateRange.value, fmResult.value.pageNo, fmResult.value.pageSize);
		fmResult.value = fmr as FMDataListResult;
		uni.hideLoading();
		submitLoading.value = false;
	}
	const dateChange = (range : string[]) => {
		dateRange.value = range;
		getFmList();

	}
	const searchInputChange = (k : string) => {
		keyword.value = k;
	}
	const selectFm = (bt : string) => {
		billType.value = bt;
		getFmList();
	}
	const pageChange = (pn : number) => {
		console.log(pn, fmResult.value);
		getFmList();
	}
	const formatDate = (timestamp : number) : string => {
		return dayuts(new Date(timestamp)).format("YYYY-MM-DD");
	}
	const addFm = async () => {
		if (!permissionList.value.includes(
			"FM_CREATE"
		)) {
			showDialog({
				title: '没有足够的权限',
				message: "请联系负责人",
				showCancelButton: false,
				confirm: () => {
					hideDialog();
				}
			})
			return;
		}
		uni.$once("refrushfmList", ()=>{
			console.log("刷新fmlist");
			getFmList();
		})
		uni.navigateTo({
			url: `/pages/financialManagement/inExManage/createIncomeAndExpense/createIncomeAndExpense?billType=${billType.value}`
		});
		
		
	}
	const deleteFm = async (fm : FMBean)=> {
		if (submitLoading.value == true) {
			return;
		}
		if (!permissionList.value.includes(
			"ROOMTYPE_DELETE"
		)) {
			showDialog({
				title: '没有足够的权限',
				message: "请联系负责人",
				showCancelButton: false,
				confirm: () => {
					hideDialog();

				}
			})
			return;
		}
		console.log("delete")
		showDialog({
			title: '确认删除此收支单',
			message: "删除后将无法恢复，确认删除吗？",
			beforeClose: async () : Promise<boolean> => {

				//await roomTypeService.deleteFm(room._id);
				//await comFunction.getRoomTypeList(hotel_id.value);
				try {
					await FMService.deleteFm(fm._id);
					getFmList();
					hideDialog();
				} catch (errMsg) {
					uni.showToast({
						title:'删除异常，请重试',
						icon:"none"
					})
				}
			

			},
			confirm: () => {
			}, cancel: () => {
				hideDialog();
			}

		});
	}
	const editFm = async (fm : FMBean) => {
		if (!permissionList.value.includes(
			"ROOMTYPE_UPDATE"
		)) {
			showDialog({
				title: '没有足够的权限',
				message: "请联系负责人",
				showCancelButton: false,
				confirm: () => {
					hideDialog();
				}
			})
			return;
		}
	}
	const init = () => {
		//let d:MOONTH_START_END_TIMESTAMP=TIME.getTodayStartTimeAndEndTime(new Date());
		getFmList();
	}
	onPageShow(()=>{
		//getFmList();
	})
	init();
</script>

