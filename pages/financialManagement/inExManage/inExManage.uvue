				</view>
				<view class="card-item  select-area" style="margin-bottom: 0;">
					<fmSearchComponent :columns="columns" :initDateRange="dateRange"
						@searchInputChange="searchInputChange" @selectAction="selectFm" @dateChange="dateChange"
						@searchAction="getFmList" placeholder="搜索收入名称"></fmSearchComponent>
				</view>
				<!-- <view class="card-item search"></view> -->
			</view>

		</view>
		<view style="padding:20px;border-radius: 8px;"> 
		<rice-collapse  :custom-style="{borderRadius:'8px'}">
		  <rice-collapse-item  v-for="fm of fmResult.fmList" :name="fm._id" :title="`${fm.type_text}:￥${fm.amount}`" :value="formatDate(fm.ioeTime)" :title-style="{color:fm.billType=='expenses'?'#b91c1c':'#047857'}">
			  <view class="l-card">		
			  <!-- 	<view class="amount-area">
			  		<view><text class="label">{{fm.billType=='expenses'?'本次支出':'本次收入'}}</text></view>
			  		<view><text  :class="['num',fm.billType=='expenses'?'num-red':'']">￥{{fm.amount}}</text></view>
			  	</view> -->
			  	<view class="content">
			  	<!-- 	<view class="card-item title">
			  			<text class="txt">{{formatDate(fm.ioeTime)}}</text>
			  		</view> -->
			  		<view class="card-item" >
			  			<view class="fl-c"> 
			  				<image src="/static/icons/fm/time.png" style="width: 16px;height: 16px;"></image>
			  				<text class="label">收支时间：</text> 
			  			</view>
			  		<text class="val-style">{{formatDate(fm.ioeTime)}}</text>
			  	</view>
			  		<view class="card-item">
			  			<view class="fl-c"> 
			  			<image src="/static/icons/fm/sztype.png" style="width: 16px;height: 16px;"></image>
			  			<text class="label">交易类型：</text>
			  			</view>
			  			 <text class="val-style">{{fm.type_text}}</text>
			  		</view>
					<view class="card-item" v-if="fm.billType=='income'">
						<view class="fl-c"> 
						<image src="/static/icons/fm/income.png" style="width: 16px;height: 16px;"></image>
						<text class="label">收入金额：</text>
						</view>
						 <text class="val-style" style="color:#047857">¥{{fm.amount}}</text>
					</view>
					<view class="card-item" v-if="fm.billType=='expenses'">
						<view class="fl-c"> 
						<image src="/static/icons/fm/expenses.png" style="width: 16px;height: 16px;"></image>
						<text class="label">支出金额：</text>
						</view>
						 <text class="val-style" style="color:#b91c1c">¥{{fm.amount}}</text>
					</view>
					<view class="card-item">
						<view class="fl-c"> 
						<image src="/static/icons/fm/sztype.png" style="width: 16px;height: 16px;"></image>
						<text class="label">支出：</text>
						</view>
						 <text class="val-style">{{fm.type_text}}</text>
					</view>
			  		<view class="card-item" style="margin-bottom: 0;">
			  			<view class="fl-c"> 
			  			<image src="/static/icons/fm/mark.png" style="width: 16px;height: 16px;"></image>
			  			<text class="label">备注信息：</text>
			  			</view>
			  			<text class="val-style">
			  				{{fm.mark}}
			  			</text>
			  		</view>
			  	</view>
			  
			  	<view class="control">
			  		<view>
			  			<xt-control @del="deleteFm(fm)" @edit="editFm(fm)" :show-view="false"></xt-control>
			  		</view>
			  
			  
			  	</view>
			  </view>
		  </rice-collapse-item>
		 
		</rice-collapse>
		</view >
		<view class="card-list"  v-if="false&&!submitLoading&&fmResult.fmList.length>0">
		
			<view  class="card-list-item" v-for="fm of fmResult.fmList">
				<view class="card">
					<view class="icon-area">
						<image src="/static/icons/fm/in.png" style="width: 20px;height: 20px;"
							v-if="fm.billType=='income'"></image>
						<image src="/static/icons/fm/expense.png" style="width: 20px;height: 20px;"
							v-if="fm.billType=='expenses'"></image>
					</view>
					<view class="top-area" v-if="fm.billType=='income'">
						<image  src="/static/icons/fm/in.png" style="width: 18px;height: 18px;"></image>
						<text  class="txt">收入</text>
					</view>
					<view   class="top-area-red" v-if="fm.billType=='expenses'">
						<image src="/static/icons/fm/expense.png" style="width: 18px;height: 18px;"></image>
						<text  class="txt">支出</text>
					</view>
					<!-- <view class="amount-area">
						<view><text class="label">{{fm.billType=='expenses'?'本次支出':'本次收入'}}</text></view>
						<view><text  :class="['num',fm.billType=='expenses'?'num-red':'']">￥{{fm.amount}}</text></view>
					</view> -->
					<view class="content">
					<!-- 	<view class="card-item title">
							<text class="txt">{{formatDate(fm.ioeTime)}}</text>
						</view> -->
						<view class="card-item" >
							<view class="fl-c"> 
								<image src="/static/icons/fm/time.png" style="width: 16px;height: 16px;"></image>
								<text class="label">收支时间：</text> 
							</view>
						<text class="val-style">{{formatDate(fm.ioeTime)}}</text>
					</view>
						<view class="card-item">
							<view class="fl-c"> 
							<image src="/static/icons/fm/sztype.png" style="width: 16px;height: 16px;"></image>
							<text class="label">交易类型：</text>
							</view>
							 <text class="val-style">{{fm.type_text}}</text>
						</view>
							<view class="card-item">
						<text class="label">收支金额：</text><text class="val-style">
							{{fm.amount}}
						</text>
					</view>
						<view class="card-item" style="margin-bottom: 0;">
