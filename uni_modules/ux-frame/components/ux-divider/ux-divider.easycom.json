{
  "name": "",
  "description": "支持横向、竖向，可配置非细线、虚线",
  "tutorial": "https://www.uxframe.cn/component/divider.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "",
      "type": "Event"
    },
    {
      "name": "theme",
      "description": "String | 按钮类型",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 颜色 ( 默认 $ux.Conf.borderColor )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "direction",
      "description": "String | 方向 (默认 row )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'row'\n\t\t}"
    },
    {
      "name": "hairline",
      "description": "Boolean | 细线条 (默认 true )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "dashed",
      "description": "Boolean | 虚线 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "margin",
      "description": "Array | 边距 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "mt",
      "description": "Any | 距上 单位px",
      "type": "Any"
    },
    {
      "name": "mr",
      "description": "Any | 距右 单位px",
      "type": "Any"
    },
    {
      "name": "mb",
      "description": "Any | 距下 单位px",
      "type": "Any"
    },
    {
      "name": "ml",
      "description": "Any | 距左 单位px",
      "type": "Any"
    },
    {
      "name": "padding",
      "description": "Array | 填充 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "pt",
      "description": "Any | 上内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pr",
      "description": "Any | 右内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pb",
      "description": "Any | 下内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pl",
      "description": "Any | 左内边距 单位px",
      "type": "Any"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "Array"
    }
  ]
}