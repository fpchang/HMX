	/**
	 *  办理入住订单
	 * st 日期
	 */
	async getOrderListByCheckIn(hotel_id : string, st : number | string) : Promise<orderBean[]> {
		const datestr = dayuts(st as number).format("YYYY/MM/DD  14:00:00");
		let startTime = dayuts(datestr).valueOf();
		let jql = `hotel_id=='${hotel_id}'&&orderStatus==1&&checkInStartDateTimeStamp==${startTime}`;
		
		try {
			const res= await DB.getCollection("hm-order", jql);
			const data = res['data'] as Array<UTSJSONObject>;
			let orderList : Array<orderBean> = []
			if (data != null) {
				data.forEach((item : UTSJSONObject) => {
					const order = formatOrder(item)
					orderList.push(order);
				})
			}
			//console.log("条件订单列表：", orderList);
			return orderList;
		} catch (error) {
			throw new Error("通过日期请求订单失败")
		}
	}
	/**
 *  退房订单
 * ed 日期
 */
   async getOrderListByCheckOut(hotel_id : string, ed : string | number) : Promise<orderBean[]> {
	const datestr = dayuts(ed).format("YYYY/MM/DD  12:00:00");
	let endTime = dayuts(datestr).valueOf();
		let jql = `hotel_id=='${hotel_id}'&&orderStatus==1&&checkInEndDateTimeStamp==${endTime}`;
		

		try {
			const res= await DB.getCollection("hm-order", jql);
			const data = res['data'] as Array<UTSJSONObject>;
			let orderList : Array<orderBean> = []
			if (data != null) {
				data.forEach((item : UTSJSONObject) => {
					const order = formatOrder(item)
					orderList.push(order);
				})
			}
			//console.log("条件订单列表：", orderList);
			return orderList;
		} catch (error) {
			throw new Error("通过退房请求订单失败")
		}
	}
	/**
	 *  今天住客订单
	 */
	async getOrderListToday(hotel_id : string) : Promise<orderBean[]> {
		let startTime = new Date(dayuts(new Date()).format("YYYY/MM/DD  14:00:00")).getTime();
		const s0 = `hotel_id=='${hotel_id}'&&orderStatus==1`
		const s1 = `${startTime}>=checkInStartDateTimeStamp&&${startTime}<checkInEndDateTimeStamp`;

		let jql = `${s0}&&${s1}`;
		
try {
			const res = await DB.getCollection("hm-order", jql);
			const data = res['data'] as Array<UTSJSONObject>;
			let orderList : Array<orderBean> = []
			if (data != null) {
				data.forEach((item : UTSJSONObject) => {
					const order = formatOrder(item)
					orderList.push(order);
				})
			}
			//console.log("条件订单列表：", orderList);
			return orderList;
		} catch (error) {
			throw new Error("通过日期请求订单失败")
		}
		
	}
	/**
   *  特定日期住客订单
   */
	async getOrderListByDate(hotel_id : string, date : string | number) : Promise<orderBean[]> {
		let startTime = dayuts(date).startOf('day').add(14,'hour').valueOf();
		const s0 = `hotel_id=='${hotel_id}'&&orderStatus==1`
		const s1 = `${startTime}>=checkInStartDateTimeStamp&&${startTime}<checkInEndDateTimeStamp`;

		let jql = `${s0}&&${s1}`;
		

		try {
			const res = await DB.getCollection("hm-order", jql);
			const data = res['data'] as Array<UTSJSONObject>;
			let orderList : Array<orderBean> = []
			if (data != null) {
				data.forEach((item : UTSJSONObject) => {
					const order = formatOrder(item)
					orderList.push(order);
				})
			}
			////console.log("条件订单列表：", orderList);
			return orderList;
		} catch (error) {
			throw new Error("通过日期请求订单失败")
		}
	}
	/**
	 *  根据日期范围查找订单
	 */

   getOrderListByCondition(hotel_id : string, st : string | number, et : string | number) : Promise<UniCloudDBGetResult> {
	////console.log(arguments);
	let startTime = dayuts(st).startOf('day').add(14,'hour').valueOf();
	let endTime   = dayuts(et).startOf('day').add(12,'hour').valueOf();
		const s1 = `checkInStartDateTimeStamp<${startTime}&&checkInEndDateTimeStamp>${startTime}`;
		const s2 = `checkInStartDateTimeStamp>=${startTime}&&checkInEndDateTimeStamp<=${endTime}`;
		const s3 = `checkInStartDateTimeStamp<${endTime}&&checkInStartDateTimeStamp>=${startTime}&&checkInEndDateTimeStamp>=${endTime}`
		const s4 = `checkInStartDateTimeStamp<=${startTime}&&checkInEndDateTimeStamp>=${endTime}`;

		let jql =
			`hotel_id=='${hotel_id}'&&orderStatus==1&&(${s1}||${s2}||${s3}||${s4})`;
		return DB.getCollectionOrderBy("hm-order", jql, "checkInStartDateTimeStamp asc");
	}
	/** 
   * 获取当前酒店今天以后的订单信息
  */
	async getOrderListTodayAfter(hotel_id : string) : Promise<orderBean[]> {
		let startTime = new Date(dayuts(new Date()).format("YYYY/MM/DD  14:00:00")).getTime();
		let endTime = new Date(dayuts(new Date()).format("YYYY/MM/DD  12:00:00")).getTime();
		let jql =
			`hotel_id=='${hotel_id}'&&orderStatus==1&&(checkInStartDateTimeStamp>=${startTime} ||` +
			`(${endTime}<checkInEndDateTimeStamp && ${endTime}>checkInStartDateTimeStamp))`;
		try {


			const res = await DB.getCollectionOrderBy("hm-order", jql, "checkInStartDateTimeStamp asc");
			////console.log("今天以后的订单：：",res)
			const data = res['data'] as Array<UTSJSONObject>;
			let orderList : Array<orderBean> = []
			if (data != null) {
				data.forEach((item : UTSJSONObject) => {
					const order = formatOrder(item)
					orderList.push(order);
				})
			}
			////console.log("条件订单列表：", orderList);
			return orderList;
		} catch (error) {
			throw new Error("请求房态失败")
		}
	}
	/**
	 * 
	 * @returns 删除订单
	 */
	async deleteOrder(_id : string) : Promise<boolean> {
		try {
			const res = await DB.callFunction('hm-deleteOrder', { _id });
			////console.log("删除订单",res)
			return true;
		} catch (error) {
			throw new Error("删除订单失败")
		}
		
		
	}
	//更改订单状态
	updateOrder(_id : string, obj : UTSJSONObject) : Promise<UniCloudDBUpdateResult> {
		////console.log("更新",_id,obj)
		return DB.update("hm-order", _id, obj);
	}
}
