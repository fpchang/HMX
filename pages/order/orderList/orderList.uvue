					.num {
						line-height: 36px;
						color: #047857;
						font-size: 30px;
						font-weight: 700;
					}

					.num-red {
						color: #b91c1c;
					}
				}

				.content {
					padding: 24px;

					.card-item {

						margin-top: 15px;
						display: flex;
						flex-direction: row;
						align-items: center;
						justify-content: space-between;

						&:first-child {
							margin-top: 0;
						}

						.fl-c {
							display: flex;
							flex-direction: row;
							align-items: center;
						}

						.label {
							color: #1f2937;
							font-size: 16px;
							padding-left: 8px;
						}

						.val-style {
							color: #1f2937;
							font-size: 16px;
						}

					}
				}



				.control {
					height: 44px;
					padding:0 12px 12px 0;
					display: flex;
					flex-direction: row;
					justify-content: flex-end;
			
					align-items: center;

					.txt {
						font-size: 20px;
						font-weight: 700;
						color: #f53f3f;
						padding-top: 5px;
					}

					.txt-in {
						color: #00b42a;
					}
				}
			}
		}
	}
</style>