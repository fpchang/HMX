      "name": "iconColor",
      "description": "String | 标题图标颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "iconSize",
      "description": "Any | 标题图标大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "iconStyle",
      "description": "String | 标题图标样式",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "rightIcon",
      "description": "String | 右侧图标",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
