{
  "name": "",
  "description": "基于ECharts开发的图表组件库",
  "tutorial": "https://www.uxframe.cn/component/echarts.html",
  "attributes": [
    {
      "name": "[event]message",
      "description": "Function | 回调消息",
      "type": "Function"
    },
    {
      "name": "[event]loading",
      "description": "Function | 加载中",
      "type": "Function"
    },
    {
      "name": "[event]load",
      "description": "Function | 加载完成",
      "type": "Function"
    },
    {
      "name": "[event]error",
      "description": "Function | 加载失败",
      "type": "Function"
    },
    {
      "name": "option",
      "description": "UTSJSONObject | 图表配置数据",
      "type": "{\n\t\t\tdefault: (): UTSJSONObject => {\n\t\t\t\treturn {} as UTSJSONObject\n\t\t\t}\n\t\t}"
    },
    {
      "name": "showLoading",
      "description": "Boolean | 显示加载中 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true,\n\t\t}"
    },
    {
      "name": "loadingText",
      "description": "String | 加载中文案 (默认 加载中...)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '加载中...',\n\t\t}"
    }
  ]
}