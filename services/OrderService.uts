import { orderSourceBean, orderBean,formatOrder, OrderRoomTypeBean, OrderDataListResult, remainRoomTypeBean } from '@/bean/orderBean';
type remainRoomBean = {
	_id : string
	room_name : string
}
import { DB } from '@/api/DB';
import { dayuts } from '@/uni_modules/lime-dayuts';
import { TIME, MOONTH_START_END_TIMESTAMP } from "@/static/utils/TIME";
import { roomTypeBean } from '../bean/roomTypeBean';
import { roomBean } from '../bean/roomBean';
class OrderServiceClass {
	constructor() {

	}
	async getSource() : Promise<Array<orderSourceBean>> {
		let list : Array<orderSourceBean> = [];
		try {
			const res = await DB.getCollection("hm-orderSouce", {});
			let resultList = res['data'] as Array<UTSJSONObject>;
			resultList.forEach(item => {
				let os : orderSourceBean = {
					name: item.getString("name") ?? "",
					text: item.getString("text") ?? "",
					value: item.getNumber("value") ?? 0
				}
				list.push(os);
			})
			return list;
		} catch (error) {
			throw new Error("获取订单来源失败");
		}

	}
	/**
	 * 创建订单
	 */
	async addOrder(orderObj : orderBean) : Promise<boolean> {
		const obj = {
			hotel_id: orderObj.hotel_id,
			userName: orderObj.userName,
			checkInStartDateTimeStamp: orderObj.checkInStartDateTimeStamp,
			checkInEndDateTimeStamp: orderObj.checkInEndDateTimeStamp,
			checkInStartDate: orderObj.checkInStartDate,
			checkInEndDate: orderObj.checkInEndDate,
			phone: orderObj.phone,
			createrPhone: orderObj.createrPhone,
			createrName: orderObj.userName,
			orderSource: orderObj.orderSource,
			orderSouce_Zn: orderObj.orderSouce_Zn,
			downPayment: orderObj.downPayment,
			totalAmount: orderObj.totalAmount,
			reservedRoomList: orderObj.reservedRoomList
		}
		try {
			const res = await DB.callFunction("hm_addOrder", { orderObj: obj });
			//console.log("create order", res);
			const result = res['result'] as UTSJSONObject;
			const code = result.getNumber("code", 0) ?? 0;
			const message = result.getString("message", "") ?? "";
			if (code != 0) {
				//console.log("code error", code);
				uni.showToast({
					title: message,
					icon: "none"
				});
				throw new Error(message);
			}
			return true
		} catch (error) {
			throw new Error("创建失败");
		}

	}
	async getOrderListBySearch(hotel_id : string, dateRange : string[], orderStatus : string | number, keyword : string, pageNo : number, pageSize : number) : Promise<OrderDataListResult> {
		let skipnum : number = Math.max((pageNo - 1) * pageSize, 0);
		const db = uniCloud.databaseForJQL();
		const dbCmd = db.command;
		let st : number = TIME.getCurrentMonthFirst(new Date());
		let et : number = TIME.getCurrentMonthLast(new Date());
		if (dateRange != null && dateRange.length == 2) {
			st = TIME.startTime(new Date(dateRange[0]));
			et = TIME.endTime(new Date(dateRange[1]));
		}
		//console.log("wwww", st, et);
		const w = {
			hotel_id: hotel_id,
			//checkInEndDateTimeStamp: dbCmd.and([dbCmd.gte(st), dbCmd.lte(et)]),
			checkInStartDateTimeStamp: dbCmd.and([dbCmd.gte(st), dbCmd.lte(et)]),
			orderStatus: orderStatus == 'all' ? dbCmd.neq(999) : orderStatus,
			$or: [{ userName: new RegExp(`${keyword}`) }, { wxNickName: new RegExp(`${keyword}`) }, { phone: new RegExp(`${keyword}`) }]
		}
		//console.log("过滤条件", w);
		try {
			const res = await db.collection("hm-order").where(w).orderBy("createTime desc").skip(skipnum).limit(pageSize).get({ getCount: true });
			//console.log("order request", res)
			const data = res['data'] as Array<UTSJSONObject>;
			let orderList : Array<orderBean> = []
			if (data != null) {
				data.forEach((item : UTSJSONObject) => {
					let roomTypeList : Array<OrderRoomTypeBean> = [];
					let rList = item.getArray("roomTypeArray") as Array<UTSJSONObject> ?? []
					rList.forEach((rt : UTSJSONObject) => {
						let formatRt : OrderRoomTypeBean = {
							count: rt.getNumber("count") ?? 0,
							name: rt.getString("name") ?? "",
							roomList: rt.getArray("roomList") as Array<string> ?? [],
							roomType_id: rt.getString("roomType_id") ?? ""
						}
						roomTypeList.push(formatRt)
					})
					let order : orderBean = {
						_id: item.getString("_id") ?? "",
						checkInEndDate: item.getString("checkInEndDate") ?? "",
						checkInEndDateTimeStamp: item.getNumber("checkInEndDateTimeStamp") ?? 0,
						checkInStartDate: item.getString("checkInStartDate") ?? "",
						checkInStartDateTimeStamp: item.getNumber("checkInStartDateTimeStamp") ?? 0,
						createTime: item.getNumber("createTime") ?? 0,
						createrName: item.getString("createrName") ?? "",
						createrPhone: item.getString("createrPhone") ?? "",
						downPayment: item.getNumber("downPayment") ?? 0,
						fromClient: item.getBoolean("fromClient") ?? false,
						hotel_id: item.getString("hotel_id") ?? "",
						orderSouce_Zn: item.getString("orderSouce_Zn") ?? "",
						orderSource: item.getNumber("orderSource") ?? 0,
						orderStatus: item.getNumber("orderStatus") ?? 0,
						orderType: item.getString("orderType") ?? "",
						payType: item.getString("payType") ?? "",
						phone: item.getString("phone") ?? "",
						roomTypeArray: roomTypeList,
						reservedRoomList: item.getArray<string>("reservedRoomList") ?? [],
						totalAmount: item.getNumber("totalAmount") ?? 0,
						userName: item.getString("userName") ?? "",
						wxNickName: item.getString("wxNickName") ?? "",
						mark: item.getString("mark") ?? ""
					}
					orderList.push(order);
				})
			}
			let OrderDataListResult : OrderDataListResult = {
				count: res['count'] as number,
				pageNo: pageNo ?? 1,
				pageSize: pageSize ?? 20,
				orderList: orderList
			}
			//console.log("条件订单列表：", OrderDataListResult);
			return OrderDataListResult;
		} catch (error) {
			throw new Error("获取订单列表失败")
		}



	}

	async getRemainderRoomList(hotel_id : string, startTime : number, endTime : number) : Promise<Array<roomBean>> {
		let params = {
			hotel_id: hotel_id,
			startTime: startTime,
			endTime: endTime
		}
		//console.log("params", params);
		let list : roomBean[] = [];

		try {
			const db = uniCloud.databaseForJQL();
			let jql = `hotel_id=='${hotel_id}'&&orderType=='normal'&&(orderStatus==0||orderStatus==1)&&(` +
				`${endTime}<=checkInEndDateTimeStamp&&${endTime}>checkInStartDateTimeStamp||` +
				`${startTime}>=checkInStartDateTimeStamp&&${endTime}<=checkInEndDateTimeStamp||` +
				`${startTime}>=checkInStartDateTimeStamp&&${startTime}<checkInEndDateTimeStamp||` +
				`${startTime}<=checkInStartDateTimeStamp&&${endTime}>=checkInEndDateTimeStamp)`;
			//console.log("jql", jql);
			const orderListRes = await db.collection('hm-order').where(jql).get();
			//console.log("orderlist", orderListRes);
			const roomListRes = await db.collection('hm-room').where(`hotel_id=='${hotel_id}'`).get();
			const orderList = orderListRes.data;
			let hasUseRoomList = new Set<string>([]);
			let remainRoomList : Array<roomBean> = [];
			let roomList : Array<roomBean> = [];
			roomListRes.data.forEach(item => {
				let room : roomBean = {
					_id: item.getString("_id") ?? "",
					data_status: item.getNumber("data_status") ?? 1,
					hotel_id: item.getString("hotel_id") ?? "",
					room_name: item.getString("room_name") ?? "",
					room_type_id: item.getString("room_type_id") ?? ""
				}
				roomList.push(room)
			})
			orderList.forEach(item => {
				let list = item.getArray<string>("reservedRoomList") ?? [];
				list.forEach(room => {
					hasUseRoomList.add(room);
				})

			});
			remainRoomList = roomList.filter(item => !hasUseRoomList.has(item._id));
			//console.log("remainlist", remainRoomList);
			return remainRoomList;
			// const res = await DB.callFunction("hm_getRemainderRoomList", params);
			// //console.log("hm_getRemainderRoomList", res);
			// let result = res['result'] as Array<UTSJSONObject>;						
			// if (result == null) {
			// 	return list;
			// }
			// result.forEach(item => {
			// 	let room : roomBean = {
			// 		_id: item.getString("_id"),
			// 		data_status: item.getNumber("data_status") ?? 1,
			// 		hotel_id: item.getString("hotel_id") ?? "",
			// 		room_name: item.getString("room_name") ?? "",
			// 		room_type_id: item.getString("room_type_id") ?? ""
			// 	}
			// 	list.push(room)
			// })
			return list;
		} catch (error) {

			throw new Error("获取剩余房间失败");
		}
	}
