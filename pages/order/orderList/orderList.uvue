<template>
  <view class="order-card-container">
    <!-- iOS 侧滑菜单容器 -->
    <view class="swipe-menu" 
          @touchstart="handleTouchStart" 
          @touchmove="handleTouchMove" 
          @touchend="handleTouchEnd">
      <!-- 操作菜单（隐藏在右侧） -->
      <view class="menu-actions" :style="{ width: menuWidth + 'rpx' }">
        <button class="menu-btn btn-view" @click="handleView">查看</button>
        <button class="menu-btn btn-edit" @click="handleEdit">修改</button>
        <button class="menu-btn btn-delete" @click="handleDelete">删除</button>
      </view>
      
      <!-- 订单卡片（主内容） -->
      <view class="order-card" :style="{ transform: `translateX(-${menuWidth}rpx)`, transition: menuTransition }">
        <!-- 卡片头部：状态+价格 -->
        <view class="card-header">
          <view class="status-tag" :class="orderInfo.status === '已入住' ? 'status-success' : 'status-pending'">
            <text class="status-text">{{ orderInfo.status }}</text>
          </view>
          <view class="price-wrap">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{ orderInfo.price }}</text>
            <text class="price-unit">/晚</text>
          </view>
        </view>

        <!-- 卡片主内容区 -->
        <view class="card-content">
          <!-- 订单编号 -->
          <text class="order-no">订单号：{{ orderInfo.id }}</text>
          
          <!-- 核心信息网格 -->
          <view class="info-grid">
            <view class="info-item">
              <text class="info-label">客户名</text>
              <text class="info-value">{{ orderInfo.customerName }}</text>
            </view>
            <view class="info-item">
              <text class="info-label">房型</text>
              <text class="info-value">{{ orderInfo.roomType }}</text>
            </view>
            <view class="info-item">
              <text class="info-label">房间号</text>
              <text class="info-value">{{ orderInfo.roomNumber }}</text>
            </view>
          </view>

          <!-- 日期模块（iOS 卡片式内嵌） -->
          <view class="date-card">
            <view class="date-item">
              <text class="date-icon">📅</text>
              <text class="date-label">入住</text>
              <text class="date-value">{{ orderInfo.checkInDate }}</text>
            </view>
            <view class="date-divider"></view>
            <view class="date-item">
              <text class="date-icon">📆</text>
              <text class="date-label">退房</text>
              <text class="date-value">{{ orderInfo.checkOutDate }}</text>
            </view>
          </view>
        </view>

        <!-- 备注区（可选） -->
        <view class="card-remark" v-if="orderInfo.remark">
          <text class="remark-text">{{ orderInfo.remark }}</text>
        </view>

        <!-- iOS 经典右箭头 -->
        <view class="chevron-wrap">
          <text class="chevron-icon">›</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">


// 订单信息类型定义
interface OrderInfo {
  id: string;
  customerName: string;
  roomType: string;
  roomNumber: string;
  price: number;
  checkInDate: string;
  checkOutDate: string;
  status: string;
  remark?: string;
}

// 模拟订单数据
const orderInfo = ref<OrderInfo>({
  id: '20251220001',
  customerName: '张三',
  roomType: '豪华大床房',
  roomNumber: '801',
  price: 588,
  checkInDate: '2025-12-20',
  checkOutDate: '2025-12-22',
  status: '已入住',
  remark: '含双早，延迟退房至14点，免费停车1天'
});

// 侧滑菜单状态
const startX = ref<number>(0); // 触摸起始X坐标
const menuWidth = ref<number>(0); // 菜单展开宽度
const menuTransition = ref<string>('transform 0.2s ease'); // 过渡动画

// 触摸开始事件
const handleTouchStart = (e: any) => {
  startX.value = e.touches[0].clientX;
  menuTransition.value = 'none'; // 取消过渡，跟随滑动
};

// 触摸移动事件
const handleTouchMove = (e: any) => {
  const moveX = e.touches[0].clientX;
  const diffX = startX.value - moveX; // 左滑为正
  // 限制滑动范围：0 ~ 240rpx（菜单总宽度）
  if (diffX >= 0 && diffX <= 240) {
    menuWidth.value = diffX;
  }
};

// 触摸结束事件
const handleTouchEnd = () => {
  menuTransition.value = 'transform 0.2s ease'; // 恢复过渡
  // 滑动超过120rpx则完全展开，否则收起
  if (menuWidth.value > 120) {
    menuWidth.value = 240;
  } else {
    menuWidth.value = 0;
  }
};

// 菜单操作事件
const handleView = () => {
  showToast({ title: '查看订单详情', icon: 'none' });
  menuWidth.value = 0; // 收起菜单
};

const handleEdit = () => {
  showToast({ title: '进入订单修改页面', icon: 'none' });
  menuWidth.value = 0; // 收起菜单
};

const handleDelete = () => {
  // 二次确认弹窗（iOS 风格）
  showModal({
    title: '删除订单',
    content: '确定要删除该订单吗？删除后将无法恢复',
    success: (res) => {
      if (res.confirm) {
        showToast({ title: '订单已删除', icon: 'success' });
        menuWidth.value = 0; // 收起菜单
      }
    }
  });
};
</script>

<style scoped>
