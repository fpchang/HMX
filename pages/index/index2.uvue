					<operation></operation>
								
			</view>
		</view>

	</scroll-view>
	<view style="margin-top: 168px;" v-if="dataReading&&hotel_id==''">
		<l-empty description="没有酒店" />
		<view style="display: flex;flex-direction: row;align-items: center;justify-content: center;">
			<rice-button type="primary" icon="plus" text="创建酒店" @click="createHotel"></rice-button>
		</view>
	</view>
	
	<rice-popup v-model:show="showPopup" position="bottom" :closeable="true" radius="15px">

		<view class="left-container">
			<view style="flex: 1; min-height: 330px">
				<view class="black-area">
					<text>
					
						
					</text>
				</view>
				<view class="title-area">
					<view><image src="/static/icons/list-hotel.png" style="width:50px;height:50px" mode="aspectFit"></image></view>
					<view class="title">
						<text class="txt">酒店列表</text>
					</view>
					<navigator url="/pages/hotelManage/hotelList/hotelList" hover-class="none">
						<view class="btn"><text class="txt">管理</text></view>
					</navigator>
				</view>
				<scroll-view style="background:#fff;height:500px">
					<view style="display: flex;flex-wrap:wrap;flex-direction: row;">
						<view  v-for="item of hotelList" style="padding: 10px;flex:1;min-width:360px;" @click="checkHotel((item._id as string))">
							<view style="display: flex" :class="['zcard', item._id==hotel_id? 'zcard-active':'']"
								@click="checkHotel(item._id as string)">
								<view class="img-container">
									<image
										style="width: 100%; height: 100%" mode="aspectFill"
										:src="(item['firstImages'] != ''&&item['firstImages'] !=null)?item['firstImages']:'/static/images/hotel.png'" />
								</view>
