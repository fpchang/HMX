	.card {
		background: #fff;
		border-radius: 8px;
		padding: 15px;
		margin-bottom: 16px;
	}

	.card-title {
		font-size: 16px;
		font-weight: 500;
		margin-bottom: 16px;
	}

	.kpi-grid {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
	}

	.kpi-item {
		flex: 1;
		min-width: 150px;
		box-sizing: border-box;
		padding: 6px;

		.container {

			background: #f9f9f9;
			padding: 12px 6px;
			border-radius: 8px;
			text-align: center;
		}
	}

	.kpi-label {
		font-size: 14px;
		color: #757575;
	}

	.kpi-value {
		font-size: 18px;
		font-weight: 600;
		margin-top: 4px;
	}

	.item {
		display: flex;
		justify-content: space-between;
		padding: 8px 0;
		border-bottom: 1px solid #f0f0f0;
	}

	.item:last-child {
		border-bottom: none;
	}

	.label {
		font-size: 15px;
	}

	.value {
		font-size: 15px;
