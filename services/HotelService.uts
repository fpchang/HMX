}


class HotelServiceClass {
	constructor() {

	}
	async updateDateBase(){
		//await uniCloud.databaseForJQL().collection("hm-order").where({}).update({"reservedRoomList":[]})
	// const res = await DB.callFunction("hm_order_roomList_task",{});
