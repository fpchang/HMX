					position: relative;
					/*height:fit-content;*/
					padding: 0;
					
				}
			}
		}

		.control {
			position: fixed;
			bottom: 20px;
			width: 750rpx;
			padding: 0 20px 20px 20px;
			display: flex;
			align-items: center;
			justify-content: center;
			box-sizing: border-box;

			.btn {
			
				padding: 0px 100px;
				background-color:#004af6 ;
				border-radius: 33px;
