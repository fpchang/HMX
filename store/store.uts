	/**
	 * 
	 * @param {*} context 
	 * @param {*} loginSuccess 未登录进入登录页面，登录成功后触发
	 * @param {*} noLoginEvent 未登录时直接触发
	 * @returns 
	 */
	export const loginEvent=async ():Promise<string> =>{
	    const token = uni.getStorageSync("hm_token") as string | null;
	    if (token == null || token == "") {
	      //未登录
	      clearCache();      
	      return Promise.reject("未登录");                
	    }
	    
	    const res = await AccountService.validToken();
		console.log("res",res);
	    const code = res.result['code'] as number;
	    if (code != 0) {
	      const msg = res.result['msg'] as string;
	      if (msg != "") {
	        uni.showToast({
	          title: msg,
	          duration: 2000,
	          icon: "none",
	        });
	      }
	      return Promise.reject("token验证失败");
	    }
	    return Promise.resolve('token验证通过')
	};
	export const clearCache=():void=>{
	  uni.removeStorageSync("hm_token");
	  uni.removeStorageSync("user");
	  //context.commit("setUser",null);
	 // context.commit("setHotelId", "");
	};
	export const loginOut=():void=> {
	  console.log("退出登录");
	  clearCache();
	  uni.reLaunch({
	    url: "/pages/indexAdvise/indexAdvise",
	  });
	};
