				.top-area-red {
					border-bottom: 1px solid rgba(239, 68, 68, 0.2);
					background-color: #fef2f2;

					.txt {
						line-height: 60px;
						color: #b91c1c;
						font-size: 18px;
						font-weight: 700;
					}

				}

				.amount-area {
					padding: 0 24px;
					margin-top: 24px;

					.label {
						color: #6b7280;
						font-size: 14px;
						margin-bottom: 4px;
