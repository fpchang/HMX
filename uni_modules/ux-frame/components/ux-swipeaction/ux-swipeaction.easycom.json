{
  "name": "",
  "description": "支持左侧/右侧滑动操作栏，支持独立和同时配置",
  "tutorial": "https://www.uxframe.cn/component/swipeaction.html",
  "attributes": [
    {
      "name": "[event]open",
      "description": "",
      "type": "Event"
    },
    {
      "name": "[event]close",
      "description": "",
      "type": "Event"
    },
    {
      "name": "[event]click",
      "description": "",
      "type": "Event"
    },
    {
      "name": "left",
      "description": "Slot | 左侧按钮插槽",
      "type": "Slot"
    },
    {
      "name": "right",
      "description": "Slot | 右侧按钮插槽",
      "type": "Slot"
    },
    {
      "name": "backgroundDark",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色 (默认 auto)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'auto'\n\t\t}"
    },
    {
      "name": "threshold",
      "description": "Number | 临界值 (默认 30 )",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 30\n\t\t}"
    },
    {
      "name": "duration",
      "description": "Number | 过度时间 (默认 200 )",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 200\n\t\t}"
    },
    {
      "name": "disabled",
      "description": "Boolean | 禁用 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "background",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: '#ffffff'\n\t\t}"
    }
  ]
}