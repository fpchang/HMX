{
  "name": "",
  "description": "支持图标、标题、副标题及样式自定义，支持内边距和外边距设置，可显示阴影和边框",
  "tutorial": "https://www.uxframe.cn/component/card.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "",
      "type": "Event"
    },
    {
      "name": "direction",
      "description": "String | 布局方向",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'row'\n\t\t}"
    },
    {
      "name": "title",
      "description": "String | 标题",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "size",
      "description": "Any | 标题大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 标题颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "bold",
      "description": "Boolean | 标题加粗 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "titleStyle",
      "description": "String | 标题样式",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "subtitle",
      "description": "String | 副标题",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "subtitleColor",
      "description": "String | 副标题颜色 (默认 $ux.Conf.secondaryColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "subtitleSize",
      "description": "Any | 副标题大小 (默认 $ux.Conf.fontColor.small)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "subtitleStyle",
      "description": "String | 副标题样式",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "icon",
      "description": "String | 标题图标",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "iconColor",
      "description": "String | 标题图标颜色 (默认 $ux.Conf.fontColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "iconSize",
      "description": "Any | 标题图标大小 (默认 $ux.Conf.fontSize)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "iconStyle",
      "description": "String | 标题图标样式",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "customFamily",
      "description": "String | 自定义字体family",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "background",
      "description": "String | 背景色 (默认 $ux.Conf.backgroundColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "backgroundDark",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色 (默认 auto)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "showBlur",
      "description": "Boolean | 开启模糊背景 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "blurRadius",
      "description": "Number | 模糊半径 (默认 10 )",
      "type": "{\n\t\t\ttype: Number,\n\t\t\tdefault: 10\n\t\t}"
    },
    {
      "name": "blurColor",
      "description": "String | 模糊颜色  (默认 rgba(255, 255, 255, 0.3) )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'rgba(255, 255, 255, 0.3)'\n\t\t}"
    },
    {
      "name": "shadow",
      "description": "Boolean | 显示阴影 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "border",
      "description": "Boolean | 显示边框 (默认 false )",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "borderColor",
      "description": "String | 边框颜色  (默认 $ux.Conf.borderColor )",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "borderDarkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色 (默认 auto)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'auto'\n\t\t}"
    },
    {
      "name": "radius",
      "description": "Any | 圆角 (默认 $ux.Conf.radius)",
      "type": "{\n\t\t\tdefault: -1\n\t\t}"
    },
    {
      "name": "padding",
      "description": "Any | 内部水平边距 (默认 $ux.Conf.padding)",
      "type": "{\n\t\t\tdefault: -1\n\t\t}"
    },
    {
      "name": "margin",
      "description": "Any | 边距 (默认 $ux.Conf.margin)",
      "type": "{\n\t\t\tdefault: -1\n\t\t}"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "{\n\t\t\ttype: Array as PropType<Array<any>>,\n\t\t\tdefault: (): any[] => [] as any[]\n\t\t}"
    }
  ]
}