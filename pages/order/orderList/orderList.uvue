.card-remark {
  padding-top: 12rpx;
  border-top: 0.5rpx solid #f0f0f0;
}

.remark-text {
  font-size: 24rpx;
  color: #636366;
  line-height: 1.5;
  padding-left: 4rpx;
}

/* iOS 经典右箭头 */
.chevron-wrap {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  display: flex;
  flex-direction: row;
