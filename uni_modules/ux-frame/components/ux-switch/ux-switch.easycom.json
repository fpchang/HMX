{
  "name": "",
  "description": "扩展官方组件",
  "tutorial": "https://www.uxframe.cn/component/switch.html",
  "attributes": [
    {
      "name": "[event]change",
      "description": "Function | 值改变时触发",
      "type": "Function"
    },
    {
      "name": "[event]update:modelValue",
      "description": "",
      "type": "Event"
    },
    {
      "name": "name",
      "description": "String | 表单的控件名称，作为键值对的一部分与表单(form组件)一同提交",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "theme",
      "description": "String | 主题颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'primary'\n\t\t}"
    },
    {
      "name": "checked",
      "description": "Boolean | 是否选中 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "size",
      "description": "String | 尺寸 (默认 normal)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: 'normal'\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 颜色 (默认 $ux.Conf.primaryColor)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "darkColor",
      "description": "String | 深色 none - 不显示，auto - 自动适配深色模式，其他 - 颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: ''\n\t\t}"
    },
    {
      "name": "margin",
      "description": "Array | 边距 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "mt",
      "description": "Any | 距上 单位px",
      "type": "Any"
    },
    {
      "name": "mr",
      "description": "Any | 距右 单位px",
      "type": "Any"
    },
    {
      "name": "mb",
      "description": "Any | 距下 单位px",
      "type": "Any"
    },
    {
      "name": "ml",
      "description": "Any | 距左 单位px",
      "type": "Any"
    },
    {
      "name": "padding",
      "description": "Array | 填充 [上 右 下 左] [上下 左右] [上下左右]",
      "type": "Array"
    },
    {
      "name": "pt",
      "description": "Any | 上内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pr",
      "description": "Any | 右内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pb",
      "description": "Any | 下内边距 单位px",
      "type": "Any"
    },
    {
      "name": "pl",
      "description": "Any | 左内边距 单位px",
      "type": "Any"
    },
    {
      "name": "xstyle",
      "description": "Array<any> | 自定义样式",
      "type": "Array"
    },
    {
      "name": "disabled",
      "description": "Boolean | 是否禁用 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "modelValue",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    }
  ]
}