<script setup>
	//import {ref} from "vue";
	import gatherComponent from "./components/gatherComponent";
	import tt from "./components/tt";
	import operation from "./components/operation";
	
	import { state, setUser } from '@/store/store.uts';
	import { comFunction } from "./ComFuc.uts";	
	import {userBean} from "@/bean/userBean";
	import { hotelBean } from "@/bean/hotelBean";
	const showRange = ref(false);
	const showPopup = ref(false);
	const dateRange = ref<string[]>(["2025-9-03", "2025-9-20"]);
	const rangeConfirm = (e : string[]) => {
		//console.log(e)
	}
	const showPickTime = () => {
		showRange.value = true;
	}
	const showCheckHotel = () => {
		showPopup.value = !showPopup.value;
	}
	let dataReading=ref(false);
	const hotel_id = computed(() => {
		return state.hotel_id;
	});
	const hotel = computed(() => {
		return state.hotel;
	});
	const hotelList = computed(() => {
		return state.hotelList;
	});
	const user=computed<userBean>(() => {
		return state.user;
	});
	const topImg =():string=>{	
		if(hotel.value==null){
			return '/static/images/hotel.png';
		}
		const firstImages = hotel.value['firstImages'] as string | null;
		if(firstImages==''||firstImages==null){
			return '/static/images/hotel.png';
		}
		return firstImages;
	};
	const checkHotel = async (h_id : string) => {
		if (h_id != hotel_id.value) {
			uni.showLoading({ title: "" });
			await comFunction.checkHotel(h_id);
			showPopup.value = false;
			uni.hideLoading();

		}

	};
	const createHotel = ()=>{
		uni.navigateTo({
			url:"/pages/hotelManage/createHotel/createHotel"
		})
	}
	 // onLoad(async ():Promise<void>=>{
		//  await comFunction.init();
		//  dataReading.value=true;
	 // })
	 // onBeforeMount(async ()=>{
		//  console.log("index onBeforeMound");
		//     comFunction.init();
		//    dataReading.value=true;
		//    //return Promise.resolve({aa:111});
	 // })
	 const init = async ()=>{
		 //comFunction.loadStorage();
		 await comFunction.init();
		 dataReading.value=true;
	 }
	 watch(hotel_id,(hotel_idNew:string,hotel_idOld:string):void=>{
	 	//console.log("hotel_id change index ",hotel_idNew,hotel_idOld)
	 }); 
	    init(); 
	
	
</script>

