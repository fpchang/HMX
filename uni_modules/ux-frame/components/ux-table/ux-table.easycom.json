{
  "name": "",
  "description": "支持多种主题自定义、字段插槽、格式化、高亮、边框、斑马纹、序号、全选、单选、编辑、合计、加载状态等多种功能",
  "tutorial": "https://www.uxframe.cn/component/table.html",
  "attributes": [
    {
      "name": "[event]click",
      "description": "Function | 点击时触发",
      "type": "Function"
    },
    {
      "name": "[event]input",
      "description": "Function | 输入时触发",
      "type": "Function"
    },
    {
      "name": "[event]scrolltolower",
      "description": "Function | 滚动触底时触发",
      "type": "Function"
    },
    {
      "name": "columnkey",
      "description": "Slot | 列字段插槽",
      "type": "Slot"
    },
    {
      "name": "edit",
      "description": "Boolean | 开启编辑 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "datas",
      "description": "UTSJSONObject[] | 数据源",
      "type": "{\n\t\t\ttype: Array as PropType<UTSJSONObject[]>,\n\t\t\tdefault: () : UTSJSONObject[] => [] as UTSJSONObject[]\n\t\t}"
    },
    {
      "name": "columns",
      "description": "UxTableColumn[] | 列数据",
      "type": "{\n\t\t\ttype: Array as PropType<UxTableColumn[]>,\n\t\t\tdefault: () : UxTableColumn[] => [] as UxTableColumn[]\n\t\t}"
    },
    {
      "name": "cellHeight",
      "description": "Any | 单元格高度 (默认 40)",
      "type": "{\n\t\t\tdefault: 40\n\t\t}"
    },
    {
      "name": "height",
      "description": "Any | 表格高度",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "maxHeight",
      "description": "Any | 表格最大高度",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "headerColor",
      "description": "String | 头部内容颜色",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"#333333\"\n\t\t}"
    },
    {
      "name": "headerSize",
      "description": "Any | 头部字体大小 (默认 $ux.Conf.fontSize.small)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "headerBold",
      "description": "Boolean | 头部字体加粗 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: true\n\t\t}"
    },
    {
      "name": "headerBackground",
      "description": "String | 头部背景色 (默认 #f5f5f5)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"#f5f5f5\"\n\t\t}"
    },
    {
      "name": "color",
      "description": "String | 内容颜色 (默认 #333333)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"#333333\"\n\t\t}"
    },
    {
      "name": "fontSize",
      "description": "Any | 内容字体大小 (默认 $ux.Conf.fontSize.small)",
      "type": "{\n\t\t\tdefault: 0\n\t\t}"
    },
    {
      "name": "background",
      "description": "String | 背景色 (默认 #fafafa)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"#fafafa\"\n\t\t}"
    },
    {
      "name": "highlight",
      "description": "String | 高亮色 (默认 #ecf5ff)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"#ecf5ff\"\n\t\t}"
    },
    {
      "name": "border",
      "description": "Boolean | 显示边框 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "ripple",
      "description": "Boolean | 显示斑马纹 (默认 true)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "rippleColor",
      "description": "String | 斑马纹背景色 (默认 #f5f5f5)",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"#f5f5f5\"\n\t\t}"
    },
    {
      "name": "nums",
      "description": "Boolean | 显示序号 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "numSort",
      "description": "Boolean | 开启序号排序 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "selection",
      "description": "Boolean | 开启选择 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "total",
      "description": "Boolean | 合计 (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "loading",
      "description": "Boolean | 加载中... (默认 false)",
      "type": "{\n\t\t\ttype: Boolean,\n\t\t\tdefault: false\n\t\t}"
    },
    {
      "name": "inputColor",
      "type": "{\n\t\t\ttype: String,\n\t\t\tdefault: \"transparent\"\n\t\t}"
    }
  ]
}